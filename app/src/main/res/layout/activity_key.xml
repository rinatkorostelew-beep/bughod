<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingHorizontal="32dp"
        android:paddingTop="80dp"
        android:paddingBottom="48dp">

        <!-- Logo -->
        <ImageView
            android:id="@+id/ivLogo"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@drawable/ic_launch"
            android:background="@drawable/logo_bg"
            android:padding="20dp"
            android:layout_marginBottom="24dp" />

        <!-- Title -->
        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="BigHead"
            android:textColor="@color/white"
            android:textSize="32sp"
            android:textStyle="bold"
            android:letterSpacing="0.05"
            android:layout_marginBottom="8dp" />

        <!-- Subtitle -->
        <TextView
            android:id="@+id/tvSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Введи ключ активации"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:layout_marginBottom="40dp" />

        <!-- Key input card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardKey"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/panel_bg"
            app:cardCornerRadius="16dp"
            app:cardElevation="8dp"
            app:strokeColor="@color/accent_purple"
            app:strokeWidth="1dp"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="КЛЮЧ ДОСТУПА"
                    android:textColor="@color/accent_cyan"
                    android:textSize="10sp"
                    android:letterSpacing="0.15"
                    android:textStyle="bold"
                    android:layout_marginBottom="10dp" />

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    app:boxStrokeColor="@color/accent_purple"
                    app:hintTextColor="@color/text_muted">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etKey"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="BIGHEAD-XXXX"
                        android:inputType="textVisiblePassword"
                        android:textColor="@color/white"
                        android:textColorHint="@color/text_muted"
                        android:fontFamily="monospace"
                        android:textSize="16sp"
                        android:letterSpacing="0.1" />

                </com.google.android.material.textfield.TextInputLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Error / success message -->
        <TextView
            android:id="@+id/tvError"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/error_red"
            android:textSize="13sp"
            android:visibility="invisible"
            android:layout_marginBottom="24dp" />

        <!-- Activate button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnActivate"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="АКТИВИРОВАТЬ"
            android:textSize="14sp"
            android:letterSpacing="0.1"
            android:textStyle="bold"
            app:backgroundTint="@color/accent_purple"
            app:cornerRadius="16dp"
            android:layout_marginBottom="16dp" />

        <!-- Telegram button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnTelegram"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="🔑  Получить ключ в Telegram"
            android:textSize="13sp"
            android:letterSpacing="0.05"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            app:strokeColor="@color/accent_cyan"
            app:strokeWidth="1dp"
            android:textColor="@color/accent_cyan"
            app:cornerRadius="16dp" />

    </LinearLayout>

</ScrollView>
